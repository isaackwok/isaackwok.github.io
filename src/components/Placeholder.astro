---
import PageShell from "./PageShell.astro";
import PageHeader from "./PageHeader.astro";

interface Props {
    title: string;
    kanji: string;
    description: string;
    blurb: string;
}

const { title, kanji, description, blurb } = Astro.props;
---

<PageShell title={`${title} — Isaac Kwok`} description={description}>
    <PageHeader kanji={kanji} title={title}>
        <span lang="zh-Hant" class="font-display">準備中</span> — {blurb}
    </PageHeader>
</PageShell>
