---
import Layout from "../layouts/Layout.astro";
import Nav from "./Nav.astro";
import PageHeader from "./PageHeader.astro";

interface Props {
    title: string;
    kanji: string;
    description: string;
    blurb: string;
}

const { title, kanji, description, blurb } = Astro.props;
---

<Layout title={`${title} — Isaac Kwok`} description={description}>
    <main class="mx-auto max-w-xl px-6 pt-10 pb-24 sm:px-8 sm:pt-14 sm:pb-32">
        <Nav />

        <PageHeader kanji={kanji} title={title}>
            <span lang="zh-Hant" class="font-display">準備中</span> — {blurb}
        </PageHeader>

        <footer
            class="mt-32 flex items-baseline justify-between text-sm text-hai sm:mt-40"
        >
            <p>&copy; 2026 Isaac Kwok</p>
        </footer>
    </main>
</Layout>
