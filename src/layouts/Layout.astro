---
import { ClientRouter } from "astro:transitions";

import Player from "../components/Player.astro";
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
    lang?: string;
    ogType?: "website" | "article";
    ogImage?: string;
    publishedTime?: Date;
}

const {
    title = "Isaac Kwok — Software Engineer",
    description = "Personal site of Isaac Kwok, a software engineer crafting warm, thoughtful experiences where design meets engineering.",
    lang = "en",
    ogType = "website",
    ogImage,
    publishedTime,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogLocale = lang === "zh-Hant" ? "zh_TW" : "en_US";

// Article pages pass their hero as ogImage; everything else gets the
// site-wide social card, whose fixed 1200x630 dimensions we can vouch for.
const socialImage = ogImage ?? new URL("/og.png", Astro.site).toString();
const isDefaultSocialImage = !ogImage;

const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Isaac Kwok",
    jobTitle: "Software Engineer",
    url: Astro.site?.toString(),
    email: "mailto:isaac.kwokch@gmail.com",
    sameAs: [
        "https://www.linkedin.com/in/isaac-kwok-026b2a184/",
        "https://github.com/isaackwok",
    ],
};

/*
 * Sequential page fade: old page fades out (0.3s), the bare kami white
 * holds for 0.15s, then the new page fades in (0.3s, delayed past
 * out + hold). Keyframes live in global.css.
 */
const pageFade = {
    old: {
        name: "page-fade-out",
        duration: "0.3s",
        easing: "ease-in",
        fillMode: "both",
    },
    new: {
        name: "page-fade-in",
        duration: "0.3s",
        delay: "0.45s",
        easing: "ease-out",
        fillMode: "both",
    },
};

const pageTransition = { forwards: pageFade, backwards: pageFade };
---

<!doctype html>
<html lang={lang} transition:animate={pageTransition}>
    <head>
        <meta charset="utf-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, viewport-fit=cover"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#ffffff" />
        <meta name="description" content={description} />
        <meta name="author" content="Isaac Kwok" />
        <link rel="canonical" href={canonicalURL} />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <title>{title}</title>
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:site_name" content="Isaac Kwok" />
        <meta property="og:locale" content={ogLocale} />
        <meta property="og:image" content={socialImage} />
        {isDefaultSocialImage && <meta property="og:image:width" content="1200" />}
        {isDefaultSocialImage && <meta property="og:image:height" content="630" />}
        {
            isDefaultSocialImage && (
                <meta
                    property="og:image:alt"
                    content="Isaac Kwok — Software Engineer"
                />
            )
        }
        {
            publishedTime && ogType === "article" && (
                <meta
                    property="article:published_time"
                    content={publishedTime.toISOString()}
                />
            )
        }
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={socialImage} />
        <script
            is:inline
            type="application/ld+json"
            set:html={JSON.stringify(personSchema)}
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap"
            rel="stylesheet"
        />
        <ClientRouter />
    </head>
    <body class="washi min-h-dvh">
        <slot />
        <Player />
    </body>
</html>
