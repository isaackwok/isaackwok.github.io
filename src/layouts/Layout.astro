---
import { ClientRouter } from "astro:transitions";

import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "Isaac Kwok — Software Engineer",
    description = "Personal site of Isaac Kwok, a software engineer crafting warm, thoughtful experiences where design meets engineering.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Isaac Kwok",
    jobTitle: "Software Engineer",
    url: Astro.site?.toString(),
    email: "mailto:isaac.kwokch@gmail.com",
    sameAs: ["https://www.linkedin.com/in/isaac-kwok-026b2a184/"],
};

/*
 * Sequential page fade: old page fades out (0.3s), the bare kami white
 * holds for 0.15s, then the new page fades in (0.3s). Both animations
 * span the full 0.75s with the phases as keyframe percentages in
 * global.css — animation-delay is off-limits here because Safari
 * doesn't render delayed animations on view-transition snapshots.
 * Easing is per-phase inside the keyframes, so linear here.
 *
 * The animation lives on <body>, not <html>: capturing the root
 * element makes iOS Safari composite the snapshots over a black
 * layer instead of the page canvas. With the root left live
 * (view-transition-name: none in global.css), the kami background
 * keeps painting underneath while only the body snapshots fade.
 */
const pageFade = {
    old: {
        name: "page-fade-out",
        duration: "0.75s",
        easing: "linear",
        fillMode: "both",
    },
    new: {
        name: "page-fade-in",
        duration: "0.75s",
        easing: "linear",
        fillMode: "both",
    },
};

const pageTransition = { forwards: pageFade, backwards: pageFade };
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="color-scheme" content="light" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <meta name="author" content="Isaac Kwok" />
        <link rel="canonical" href={canonicalURL} />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <title>{title}</title>
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:site_name" content="Isaac Kwok" />
        <meta property="og:locale" content="en" />
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <script
            is:inline
            type="application/ld+json"
            set:html={JSON.stringify(personSchema)}
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap"
            rel="stylesheet"
        />
        <ClientRouter />
    </head>
    <body class="washi min-h-dvh" transition:animate={pageTransition}>
        <slot />
    </body>
</html>
