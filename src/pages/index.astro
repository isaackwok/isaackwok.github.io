---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import * as WorkExperience from "../components/WorkExperience";
import * as Contact from "../components/Contact";
---

<Layout>
    <main class="mx-auto max-w-xl px-6 pt-28 pb-24 sm:px-8 sm:pt-44 sm:pb-32">
        <!-- Hero -->
        <header>
            <p class="text-xs font-medium tracking-[0.35em] text-hai uppercase">
                Software engineer
            </p>
            <h1
                class="mt-6 font-display text-5xl font-medium tracking-tight sm:text-6xl"
            >
                Isaac Kwok
            </h1>
            <p class="mt-8 max-w-md leading-loose text-hai">
                I build quiet, careful software for the web — the kind that gets
                out of your way and lets the work breathe.
            </p>
        </header>

        <Section kanji="關於" label="About">
            <p class="leading-loose">
                I care about the small things: type that reads well, interfaces
                that respond gently, code that the next person can pick up
                without a map. Most of my days are spent somewhere between
                design and engineering, trying to close the gap between the two.
            </p>
        </Section>

        <Section kanji="仕事" label="Work">
            <WorkExperience.List>
                <WorkExperience.Row company="LINE GO" period="Present" />
                <WorkExperience.Row company="Uto.ai" />
                <WorkExperience.Row company="Bahwan CyberTek" />
                <WorkExperience.Row company="Shopee" />
            </WorkExperience.List>
        </Section>

        <Section kanji="連絡" label="Contact">
            <p class="leading-loose">The inbox is always open.</p>
            <Contact.List>
                <Contact.Row label="Email" href="mailto:isaac.kwokch@gmail.com"
                    >isaac.kwokch@gmail.com</Contact.Row
                >
                <Contact.Row
                    label="LinkedIn"
                    href="https://www.linkedin.com/in/isaac-kwok-026b2a184/"
                    >Isaac Kwok</Contact.Row
                >
            </Contact.List>
        </Section>

        <footer
            class="mt-32 flex items-baseline justify-between text-sm text-hai sm:mt-40"
        >
            <p>&copy; 2026 Isaac Kwok</p>
            <p class="font-display select-none" aria-hidden="true">郭</p>
        </footer>
    </main>
</Layout>
